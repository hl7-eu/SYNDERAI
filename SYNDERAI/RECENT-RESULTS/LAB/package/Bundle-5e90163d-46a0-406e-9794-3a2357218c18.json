                "text": {
                  "status": "generated",
                  "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><h3>Hematology</h3><table class=\"hl7__eu__lab__report\"><thead><tr><th>Test</th><th>20-APR-2019</th><th>Reference&#xA0;Range</th><th>Unit</th></tr></thead><tbody><tr><td>Leukocytes [#/volume] in Blood by Automated count</td><td>7.1</td><td>4.5 - 11.0</td><td>10*3/uL</td></tr><tr><td>Erythrocytes [#/volume] in Blood by Automated count</td><td>5.2</td><td>4.5 - 5.9</td><td>10*6/uL</td></tr><tr><td>Hemoglobin [Mass/volume] in Blood</td><td><strong>12.5 L</strong></td><td>13.5 - 17.5</td><td>g/dL</td></tr><tr><td>Hematocrit [Volume Fraction] of Blood by Automated count</td><td>39.3</td><td>36 - 50</td><td>%</td></tr><tr><td>MCV [Entitic mean volume] in Red Blood Cells by Automated count</td><td>86.2</td><td>80 - 100</td><td>fL</td></tr><tr><td>MCH [Entitic mass] by Automated count</td><td>30.2</td><td>27 - 33</td><td>pg</td></tr><tr><td>MCHC [Entitic Mass/volume] in Red Blood Cells by Automated count</td><td>34.6</td><td>32 - 36</td><td>g/dL</td></tr><tr><td>Erythrocyte distribution width [Entitic volume] by Automated count</td><td>42.6</td><td>36 - 48</td><td>fL</td></tr><tr><td>Platelets [#/volume] in Blood by Automated count</td><td>400.1</td><td>150 - 450</td><td>10*3/uL</td></tr><tr><td>Platelet distribution width [Entitic volume] in Blood by Automated count</td><td><strong>503.1 H</strong></td><td>9.4 - 12.3</td><td>fL</td></tr><tr><td>Platelet [Entitic mean volume] in Blood by Automated count</td><td><strong>10.9 H</strong></td><td>7.4 - 10.4</td><td>fL</td></tr></tbody></table></div>"
                },
                "title": "Hematology"
