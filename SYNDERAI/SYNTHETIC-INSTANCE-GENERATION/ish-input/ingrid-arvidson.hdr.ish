section*
  type careplan
  code $loinc#8653-8 Hospital Discharge Instructions
  title Follow-up and Care Plan
  text = """<ul><li>Cardiology Outpatient: Follow-up appointment in 4 weeks to review post-TAVI recovery and optimise heart failure medications</li><li>Doppler Echocardiogram: Repeat in 4 weeks to evaluate aortic valve function and ejection fraction post-TAVI</li><li>Troponin Monitoring: Periodic measurement to track cardiac biomarker trend</li><li>Electrolytes and Renal Function: Regular monitoring given ongoing diuretic and ACE inhibitor therapy</li><li>Weight Monitoring: Patient instructed to monitor daily weight and report rapid gains exceeding 2 kg suggesting fluid accumulation</li><li>Medication Compliance: Continue all discharge medications - furosemide, bisoprolol, ramipril, spironolactone, aspirin, atorvastatin, pantoprazole</li><li>Symptom Awareness: Report any worsening dyspnoea, new leg swelling, dizziness, or palpitations immediately</li></ul>"""
  entry*
