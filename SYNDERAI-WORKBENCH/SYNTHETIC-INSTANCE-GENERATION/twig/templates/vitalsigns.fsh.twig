{#
  This is the TWIG file for the creation of an FSH instance including the HTML parts.
  see README.md
  
  KH since 2025-09-02
#}

%%FSH%% {# tag required #}
Instance: {{ setInstance("Instance-Observation-" ~ instanceid) }}
InstanceOf: http://hl7.org/fhir/StructureDefinition/vitalsigns
Title: "Vital Signs"
Description: "Vital Signs"
Usage: #inline

* id = "{{ instanceid }}"

{# addign headers for HTML table #}
{{ addHEAD_tr() }}
{{ addHEAD_th("Vital Sign") }}
{{ addHEAD_th("Date") }}
{{ addHEAD_th("Measurement") }}
{{ addHEAD_trend() -}}

* status = #final

* category[VSCat].coding[0] = http://terminology.hl7.org/CodeSystem/observation-category#vital-signs "Vital Signs"

{{ addHTML_tr() }}

{# *** HTML td 1: code #}
{% if vital.code is iterable %}
* code = {{ vital.code[0].system }}#{{ vital.code[0].code }} "{{ vital.code[0].display }}"
{{ addHTML_td(vital.code[0].display) }}
{% else %}
* code = {{ vital.code.system }}#{{ vital.code.code }} "{{ vital.code.display }}"
{{ addHTML_td(vital.code.display) }}
{% endif %}

* subject = Reference(urn:uuid:{{ patient.instanceid }}) "{{ patient.name }}"

{# *** HTML td 2: date #}
* effectiveDateTime = "{{ vital.date }}"
{{ addHTML_td(vital.date|date('d-M-Y')) }}

{# should have: * performer = Reference(urn:uuid:{practitionerrole-uuid}) "{practitioner-name}" #}

{# *** HTML td 3: measurement, either single or components #}
{% if vital.value.scale == "numeric" or vital.valueQuantity.scale == "numeric" and (vital.value.value is not empty or vital.valueQuantity.value is not empty) %}
* valueQuantity.value = {{ vital.value.value ?? vital.valueQuantity.value }}
* valueQuantity.code = #{{ vital.value.code ?? vital.valueQuantity.code }}
* valueQuantity.system = "http://unitsofmeasure.org"
* valueQuantity.unit = "{{ vital.value.unit ?? vital.valueQuantity.unit }}"
{{ addHTML_td((vital.value.value ?? vital.valueQuantity.value) ~ " " ~ (vital.value.unit ?? vital.valueQuantity.unit)) }}
{% elseif vital.component is not empty %}
{% set valueunit = "-" %}
{% for c in vital.component %}
{# component with a slice? #}
{% if c.slice is not empty %}
* component[{{c.slice}}].code = {{ c.code.system }}#{{ c.code.code }} "{{ c.code.display }}"
{% else %}
* component[+].code = {{ c.code.system }}#{{ c.code.code }} "{{ c.code.display }}"
{% endif %}
* component[=].valueQuantity.value = {{ c.value.value ?? c.valueQuantity.value }}
* component[=].valueQuantity.code = #{{ c.value.code ?? c.valueQuantity.code }}
* component[=].valueQuantity.system = "http://unitsofmeasure.org"
* component[=].valueQuantity.unit = "{{ c.value.unit ?? c.valueQuantity.unit }}"
{% set valueunit = (c.value.value ?? c.valueQuantity.value) ~ " " ~ (c.value.unit ?? c.valueQuantity.unit) %}
{% endfor %} {# c in vital.component #}
{{ addHTML_td(valueunit) }}
{% else %}
{{ addHTML_td("-") }}
{% endif %}

{{ addHTML_trend() -}}

{# populate .text #}
* text.status = #generated
* text.div = """
<div xmlns="http://www.w3.org/1999/xhtml">
<table class="hl7__ips">{{ emitHEAD() | raw }}{{ emitHTML() | raw }}</table>
</div>
"""

%%HEAD%% {# tag required, content below maybe emtpy #}

%%HTML%% {# tag required, content below maybe emtpy #}
{{ emitHTML() | raw }}