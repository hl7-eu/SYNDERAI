{#
  ============================================================================
  TEMPLATE: immunizationrecommendation_fsh.twig
  ============================================================================
  PURPOSE
    Generates a FSH ImmunizationRecommendation instance (base FHIR R4 — no
    additional EU profile). Each invocation represents a single vaccine
    recommendation for the patient, carrying a target vaccine code, an
    optional due date, and an optional vaccination series description.

  PROFILE CONFORMANCE
    InstanceOf: ImmunizationRecommendation (base FHIR R4)
    Note: the resource uses `patient` (not `subject`) as the patient reference
    element name — this is specific to ImmunizationRecommendation in FHIR R4.

  INSTANCE NAME PREFIX
    The instance name uses the abbreviated prefix "Instance-ImmunRecommendation-"
    rather than a full resource-type prefix. This is intentional shortening
    to keep the name compact.

  THREE-COLUMN HTML TABLE
    Column 1 — Vaccine code display            (always present)
    Column 2 — Due date                        (conditional; "-" if absent)
    Column 3 — Vaccination series description  (used as "Reason"; "-" if absent)

  SINGLE-RECOMMENDATION PATTERN
    All recommendation sub-elements use explicit `[0]` indexing throughout,
    since this template always produces exactly one recommendation per instance:
      `recommendation[0].vaccineCode`
      `recommendation[0].targetDisease`
      `recommendation[0].dateCriterion[0].*`
      `recommendation[0].series`
      `recommendation[0].forecastStatus`
      `recommendation[0].supportingImmunization[0]`

  FIXED FIELDS
    Two fields are hardcoded for all recommendations:
      forecastStatus = #due "Due"
        (from http://terminology.hl7.org/CodeSystem/immunization-recommendation-status)
      dateCriterion[0].code = $loinc#30980-7 "Date vaccine due"
        (LOINC code identifying the criterion as the due date; only emitted
         when dateDue is present)

  SUPPORTING IMMUNIZATION REFERENCE
    When `immunizationrecommendation.supportingImmunization` is non-empty it
    is treated as the UUID of an existing Immunization resource (typically
    generated by immunization-ips_fsh.twig) and emitted as a
    `recommendation[0].supportingImmunization[0]` Reference. This links the
    recommendation back to a prior administration.

  CONTEXT VARIABLES
  ┌─────────────────────────────────────────────────┬──────────┬────────────────────────────────────────────┐
  │ Variable                                        │ Type     │ Description                                │
  ├─────────────────────────────────────────────────┼──────────┼────────────────────────────────────────────┤
  │ instanceid                                      │ string   │ Unique resource id.                        │
  │ patient.instanceid                              │ string   │ UUID of the Patient resource.              │
  │ patient.name                                    │ string   │ Full display name for the Reference.       │
  │ immunizationrecommendation.recommendationCreated│ string   │ ISO 8601 date the recommendation was       │
  │                                                 │          │ created; stored in resource-level `date`.  │
  │ immunizationrecommendation.vaccineCode          │ string   │ SNOMED CT code for the recommended vaccine.│
  │ immunizationrecommendation.vaccineCodeDisplay   │ string   │ Display text; used in FSH and HTML td 1.   │
  │ immunizationrecommendation.targetDisease        │ string?  │ Optional SNOMED CT code for the target     │
  │                                                 │          │ disease. FSH only; not in HTML.            │
  │ immunizationrecommendation.targetDiseaseDisplay │ string?  │ Display for targetDisease.                 │
  │ immunizationrecommendation.dateDue              │ string?  │ Optional ISO 8601 due date. When present,  │
  │                                                 │          │ emits dateCriterion with LOINC#30980-7.    │
  │                                                 │          │ HTML td 2: pill badge d-M-Y; "-" if absent.│
  │ immunizationrecommendation.seriesText           │ string?  │ Optional free-text vaccination series      │
  │                                                 │          │ description (e.g. "Booster dose 1").       │
  │                                                 │          │ Stored in recommendation[0].series.        │
  │                                                 │          │ HTML td 3: plain cell; "-" if absent.      │
  │ immunizationrecommendation.supportingImmunization│ string? │ Optional UUID of a supporting Immunization │
  │                                                 │          │ resource (prior administration).           │
  └─────────────────────────────────────────────────┴──────────┴────────────────────────────────────────────┘

  CODESYSTEMS REFERENCED
    $sct   — SNOMED CT; vaccineCode and targetDisease (caller-supplied codes)
    $loinc — LOINC#30980-7 "Date vaccine due" (fixed dateCriterion code)
    http://terminology.hl7.org/CodeSystem/immunization-recommendation-status
           — #due "Due" (fixed forecastStatus)

  AUTHOR   KH
  SINCE    2025-09-09
  ============================================================================
#}

%%FSH%% {# ── Section marker required by the FSH pre-processor ─────────────── #}

{# Abbreviated prefix intentional: "ImmunRecommendation" not full resource type name #}
Instance: {{ setInstance("Instance-ImmunRecommendation-" ~ instanceid) }}
InstanceOf: ImmunizationRecommendation
Title: "Immunization Recommendation"
Description: "Immunization Recommendation"
Usage: #inline

* id = "{{ instanceid }}"

{#
  ── HEAD bag: three-column table header ────────────────────────────────────
  Column 3 is labelled "Reason" but carries the vaccination series description.
#}
{{ addHEAD_tr() }}
{{ addHEAD_th("Immunization Recommendation") }}
{{ addHEAD_th("Due Date") }}
{{ addHEAD_th("Reason") }}
{{ addHEAD_trend() -}}

{{ addHTML_tr() }}

{#
  ── Resource-level date ─────────────────────────────────────────────────────
  `date` is the ImmunizationRecommendation.date (when the recommendation was
  created), not the due date of the vaccination.
#}
* date = "{{ immunizationrecommendation.recommendationCreated }}"

{#
  ── Patient reference ───────────────────────────────────────────────────────
  Note: ImmunizationRecommendation uses `patient` as the element name
  (not `subject` as used by Observation and other resources).
#}
* patient = Reference(urn:uuid:{{ patient.instanceid }}) "{{ patient.name }}"

{#
  ── Vaccine code (td 1: always present) ────────────────────────────────────
  Explicit [0] index throughout — this template always has exactly one
  recommendation per instance. vaccineCode is a CodeableConcept with a single
  SNOMED CT coding.
#}
* recommendation[0].vaccineCode = $sct#{{ immunizationrecommendation.vaccineCode }} "{{ immunizationrecommendation.vaccineCodeDisplay }}"
{{ addHTML_td(immunizationrecommendation.vaccineCodeDisplay) }}

{#
  ── Target disease (conditional; FSH only) ─────────────────────────────────
  When present, qualifies the recommendation with the specific disease being
  prevented. Not reflected in the HTML table.
#}
{% if immunizationrecommendation.targetDisease is not empty %}
* recommendation[0].targetDisease = $sct#{{ immunizationrecommendation.targetDisease }} "{{ immunizationrecommendation.targetDiseaseDisplay }}"
{% endif %}

{#
  ── Due date (td 2: conditional) ───────────────────────────────────────────
  When absent: HTML shows "-", no FSH rules emitted.
  When present: emits a dateCriterion with the fixed LOINC "Date vaccine due"
  code; HTML shows the date as a pill badge (d-M-Y format).
#}
{% if immunizationrecommendation.dateDue is empty %}
{{ addHTML_td("-") }}
{% else %}
* recommendation[0].dateCriterion[0].code = $loinc#30980-7 "Date vaccine due"
* recommendation[0].dateCriterion[0].value = "{{ immunizationrecommendation.dateDue }}"
{{ addHTML_tdnb(immunizationrecommendation.dateDue|date('d-M-Y')) }}
{% endif %}

{#
  ── Series text (td 3: conditional) ────────────────────────────────────────
  Free-text description of the vaccination series (e.g. "Booster dose 1").
  Stored in recommendation[0].series. Shown in the "Reason" HTML column.
  When absent: HTML shows "-", no FSH rule emitted.
#}
{% if immunizationrecommendation.seriesText is empty %}
{{ addHTML_td("-") }}
{% else %}
* recommendation[0].series = "{{ immunizationrecommendation.seriesText }}"
{{ addHTML_td(immunizationrecommendation.seriesText) }}
{% endif %}

{#
  ── Fixed forecast status ───────────────────────────────────────────────────
  All generated recommendations use status #due — the vaccine is overdue or
  due for administration.
#}
* recommendation[0].forecastStatus = http://terminology.hl7.org/CodeSystem/immunization-recommendation-status#due "Due"

{#
  ── Supporting immunization reference (conditional) ─────────────────────────
  Links this recommendation back to a prior immunization resource (e.g. a
  previous dose in the same series). The value is a UUID string referencing
  an Immunization instance generated by immunization-ips_fsh.twig.
#}
{% if immunizationrecommendation.supportingImmunization is not empty %}
* recommendation[0].supportingImmunization[0] = Reference(urn:uuid:{{ immunizationrecommendation.supportingImmunization }})
{% endif %}

{{ addHTML_trend() -}}

{#
  ── FHIR narrative ───────────────────────────────────────────────────────────
  Only emitHTML() flushed here — no headers in the inline narrative.
#}
* text.status = #generated
* text.div = """
<div xmlns="http://www.w3.org/1999/xhtml">
<table class="hl7__ips">{{ emitHTML() | raw }}</table>
</div>
"""

%%HEAD%% {# ── Section marker required by the FSH pre-processor ─────────────── #}
{{ emitHEAD() | raw }}

%%HTML%% {# ── Section marker required by the FSH pre-processor ─────────────── #}
{{ emitHTML() | raw }}
