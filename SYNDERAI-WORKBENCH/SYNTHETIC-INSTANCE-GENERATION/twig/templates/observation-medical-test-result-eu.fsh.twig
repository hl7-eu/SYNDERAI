%%FSH%% {# tag required #}
Instance: {{ setInstance("Instance-Observation-" ~ instanceid) }}
InstanceOf: MedicalTestResultEuCore
Title: "Medical Test Results"
Description: "Medical Test Results"
Usage: #inline

{# special handling of category.coding, see also https://github.com/hl7-eu/SYNDERAI/issues/100 #}
{% if isVitaLSignCode %}
* category[VSCat].coding = $observation-category#vital-signs
* performer[+].display = "The Central European Examiners"
{# * performer[=] = Reference(urn:uuid:e512e2e2-9600-4c69-a269-af3ab5421e09) #}
{% elseif isImagingCode %}
* category.coding = $observation-category#imaging
* performer[+].display = "The Central European Radiology"
{# * performer[=] = Reference(urn:uuid:e512e2e2-9600-4c69-a269-af3ab5421e09) #}
{% else %}
* category.coding = $observation-category#laboratory
* performer[+].display = "The Central European Laboratory"
{# * performer[=] = Reference(urn:uuid:e512e2e2-9600-4c69-a269-af3ab5421e09) #}
{% endif %}

{% include 'observation-medical-test-body.fsh.twig' %}

